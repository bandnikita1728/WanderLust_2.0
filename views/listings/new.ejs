<% layout("layouts/boilerplate") %>
<div class="row mt-4 mb-5">
  <div class="col-md-8 offset-md-2 col-12">
    <h2 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-hotel text-danger me-2"></i>List a New Paradise Spot</h2>
    
    <div class="card border-0 shadow-sm p-4 rounded-4">
      <form action="/listings" method="POST" class="needs-validation" novalidate>
        
        <div class="mb-3">
          <label for="title" class="form-label fw-semibold text-secondary">Destination Title</label>
          <input type="text" id="title" name="listing[title]" class="form-control py-2" placeholder="e.g. Magnificent Oceanfront Villa" required>
          <div class="invalid-feedback">Please enter a charming name for your location.</div>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label fw-semibold text-secondary">Description</label>
          <textarea id="description" name="listing[description]" rows="5" class="form-control" placeholder="Write an inspiring description highlighting key amenities, beaches, or views..." required></textarea>
          <div class="invalid-feedback">Please enter a description for your listing.</div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-md-6 col-12">
            <label for="location" class="form-label fw-semibold text-secondary">City / Region</label>
            <input type="text" id="location" name="listing[location]" class="form-control py-2" placeholder="e.g. Palm Springs, California" required>
            <div class="invalid-feedback">Please provide a valid city/region.</div>
          </div>
          <div class="col-md-6 col-12">
            <label for="country" class="form-label fw-semibold text-secondary">Country</label>
            <input type="text" id="country" name="listing[country]" class="form-control py-2" placeholder="e.g. United States" required>
            <div class="invalid-feedback">Please enter the country.</div>
          </div>
        </div>

        <div class="row g-3 mb-4">
          <div class="col-md-6 col-12">
            <label for="price" class="form-label fw-semibold text-secondary">Price (INR / Night)</label>
            <div class="input-group">
              <span class="input-group-text bg-light">₹</span>
              <input type="number" id="price" name="listing[price]" min="1" class="form-control py-2" placeholder="e.g. 8500" required>
              <div class="invalid-feedback">Please input a valid price greater than 0.</div>
            </div>
          </div>
          <div class="col-md-6 col-12">
            <label for="image" class="form-label fw-semibold text-secondary">Hero Image (Direct URL)</label>
            <input type="url" id="image" name="listing[image][url]" class="form-control py-2" placeholder="https://images.unsplash.com/photo-...">
          </div>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-danger px-5 py-2 rounded-pill shadow-sm fw-bold">
            <i class="fa-solid fa-circle-plus me-1"></i>Add Listing
          </button>
          <a href="/listings" class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-bold">Cancel</a>
        </div>

      </form>
    </div>
  </div>
</div>

<script>
  // Bootstrap 5 client-side checks
  (function () {
    'use strict'
    const forms = document.querySelectorAll('.needs-validation')
    Array.prototype.slice.call(forms).forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>
