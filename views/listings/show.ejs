<% layout("layouts/boilerplate") %>
<div class="container pb-5 mt-3">
  <!-- Back Button -->
  <div class="row mb-3">
    <div class="col-12">
      <a href="/listings" class="text-decoration-none text-muted d-flex align-items-center">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to Explore Listings
      </a>
    </div>
  </div>

  <div class="row">
    <!-- Left Column: image, title, description (Col-8) -->
    <div class="col-lg-8 col-12 mb-4">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
        <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1540555700478-4be289fbecef?q=80&w=1000' %>" 
             class="card-img-top w-100" 
             style="height: 30rem; object-fit: cover;" 
             alt="<%= listing.title %>">
        
        <div class="card-body p-4">
          <h2 class="fw-bold text-dark mb-3"><%= listing.title %></h2>
          
          <h5 class="fw-bold text-secondary mb-2">About this spot</h5>
          <p class="card-text text-secondary lead" style="line-height: 1.8; white-space: pre-line;">
            <%= listing.description %>
          </p>
        </div>
      </div>
    </div>

    <!-- Right Column: pricing, location, owner controls (Col-4) -->
    <div class="col-lg-4 col-12">
      <div class="card border-0 shadow h-100 rounded-4 overflow-hidden mb-4 border-top border-5 border-danger">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <div>
            <!-- Price Badge -->
            <div class="d-flex justify-content-between align-items-center mb-4">
              <span class="fs-5 text-muted">Price</span>
              <div class="text-end">
                <span class="fs-2 fw-extrabold text-danger">₹<%= listing.price ? listing.price.toLocaleString("en-IN") : '0' %></span>
                <span class="text-muted d-block small">/ night</span>
              </div>
            </div>

            <!-- Location & Country info -->
            <div class="mb-3 d-flex align-items-center">
              <span class="badge bg-danger p-2 me-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                <i class="fa-solid fa-location-dot"></i>
              </span>
              <div>
                <span class="text-muted d-block small">Location info</span>
                <strong class="text-dark"><%= listing.location %>, <%= listing.country %></strong>
              </div>
            </div>

            <!-- Owner Info -->
            <div class="mb-4 d-flex align-items-center">
              <span class="badge bg-dark p-2 me-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                <i class="fa-solid fa-user-tie"></i>
              </span>
              <div>
                <span class="text-muted d-block small">Owner</span>
                <strong class="text-dark">Listed by <%= listing.owner && listing.owner.username ? listing.owner.username : 'Wanderer' %></strong>
              </div>
            </div>

            <hr class="text-muted mb-4">
          </div>

          <!-- Edit + Delete buttons (only if currentUser is the owner) -->
          <% if (currentUser && listing.owner && (String(currentUser._id) === String(listing.owner._id || listing.owner))) { %>
            <div class="d-grid gap-3">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger py-2 rounded-pill shadow-sm fw-bold">
                <i class="fa-solid fa-pen-to-square me-2"></i>Edit Details
              </a>
              <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline">
                <button type="submit" class="btn btn-outline-dark py-2 rounded-pill w-100 fw-bold">
                  <i class="fa-solid fa-trash me-2"></i>Delete Listing
                </button>
              </form>
            </div>
          <% } else { %>
            <div class="text-center bg-light p-3 rounded-3 mt-4 small border">
              <p class="text-secondary mb-0"><i class="fa-solid fa-circle-info text-danger me-1"></i>Contact host directly upon booking clearance.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <hr class="text-muted my-5">

  <!-- Reviews Section -->
  <div class="row">
    <!-- Left Hand Side: Review Creation Form -->
    <div class="col-md-5 col-12 mb-4">
      <div class="p-4 border rounded-4 shadow-sm bg-white">
        <% if (currentUser) { %>
          <h4 class="fw-bold text-dark mb-3"><i class="fa-regular fa-comment-dots text-danger me-2"></i>Leave a Review</h4>
          <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
            <!-- Rating select 1-5 -->
            <div class="mb-3">
              <label for="rating" class="form-label fw-semibold text-secondary">Rating</label>
              <select name="review[rating]" id="rating" class="form-select bg-light border-0 py-2 rounded-3" required>
                <option value="5" selected>★ ★ ★ ★ ★ (5/5)</option>
                <option value="4">★ ★ ★ ★ ☆ (4/5)</option>
                <option value="3">★ ★ ★ ☆ ☆ (3/5)</option>
                <option value="2">★ ★ ☆ ☆ ☆ (2/5)</option>
                <option value="1">★ ☆ ☆ ☆ ☆ (1/5)</option>
              </select>
            </div>

            <!-- Comment textarea -->
            <div class="mb-3">
              <label for="comment" class="form-label fw-semibold text-secondary">Comment</label>
              <textarea name="review[comment]" id="comment" rows="5" class="form-control bg-light border-0 rounded-3 text-secondary" placeholder="Write feedback highlighting state of local beaches or pools..." required></textarea>
              <div class="invalid-feedback">Please write a comment describing your stay.</div>
            </div>

            <button type="submit" class="btn btn-dark px-4 py-2 rounded-pill fw-bold">Submit Review</button>
          </form>
        <% } else { %>
          <div class="text-center py-4 bg-light rounded-4">
            <i class="fa-solid fa-lock text-muted fs-2 mb-3"></i>
            <h5 class="fw-bold">Sign in to Review</h5>
            <p class="text-secondary small">Only verified guest members can contribute reviews.</p>
            <a href="/login" class="btn btn-danger btn-sm rounded-pill px-4">Log In</a>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Right Hand Side: List of Reviews -->
    <div class="col-md-7 col-12">
      <h4 class="fw-bold text-dark mb-4">
        <i class="fa-regular fa-comments text-danger me-2"></i>Guest Reviews (<%= listing.reviews ? listing.reviews.length : 0 %>)
      </h4>

      <% if (!listing.reviews || listing.reviews.length === 0) { %>
        <div class="alert alert-light text-center py-5 border rounded-4 bg-light shadow-sm text-muted">
          <i class="fa-solid fa-circle-question fs-3 mb-2"></i>
          <p class="mb-0 fw-semibold">No reviews registered yet.</p>
          <p class="small text-secondary mb-0">Be the first guest to share your rating experience!</p>
        </div>
      <% } else { %>
        <div class="row row-cols-1 row-cols-sm-2 g-3">
          <% for (let review of listing.reviews) { %>
            <div class="col">
              <div class="card h-100 shadow-sm border-0 rounded-3 bg-white p-3 d-flex flex-column justify-content-between">
                <div>
                  <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                      <strong class="text-dark d-block"><%= review.author && review.author.username ? review.author.username : 'Wanderer' %></strong>
                    </div>
                    <!-- Stars Display -->
                    <div class="small">
                      <% for (let i = 1; i <= 5; i++) { %>
                        <i class="fa-<%= i <= review.rating ? 'solid text-warning' : 'regular text-muted' %> fa-star"></i>
                      <% } %>
                    </div>
                  </div>
                  
                  <p class="card-text text-secondary mb-3 small" style="line-height: 1.6; white-space: pre-wrap;"><%= review.comment %></p>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                  <span class="text-muted small" style="font-size: 10px;">
                    <i class="fa-solid fa-calendar-alt me-1"></i>Verified Stay
                  </span>
                  <% if (currentUser && review.author && (String(currentUser._id) === String(review.author._id || review.author))) { %>
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="d-inline mb-0">
                      <button class="btn btn-outline-danger btn-sm rounded-pill px-3 py-1 border-0" style="font-size: 11px;">
                        <i class="fa-solid fa-trash me-1"></i>Delete
                      </button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  // Enable Bootstrap forms client-side validations
  (function () {
    'use strict'
    const forms = document.querySelectorAll('.needs-validation')
    Array.prototype.slice.call(forms).forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>
