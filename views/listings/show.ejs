<% layout("layouts/boilerplate") %>
<div class="row mt-4 mb-5">
  <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1 col-12">
    
    <!-- Notifications inside details flow -->
    <% if (success && success.length) { %>
      <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
        <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
        <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <h2 class="fw-bold mb-3 text-dark"><%= listing.title %></h2>
    
    <!-- Detail Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
      <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1540555700478-4be289fbecef?q=80&w=1000' %>" 
           class="card-img-top w-100" 
           style="height: 28rem; object-fit: cover;" 
           alt="<%= listing.title %>">
      
      <div class="card-body p-4">
        <p class="text-muted mb-3">Owned by <span class="fw-semibold text-dark"><%= listing.owner && listing.owner.username ? listing.owner.username : 'Wanderer' %></span></p>
        
        <p class="lead text-secondary mb-4" style="line-height: 1.7; white-space: pre-line;"><%= listing.description %></p>
        
        <hr class="text-muted my-4">
        
        <div class="row text-center g-3">
          <div class="col-4 border-end">
            <span class="text-muted d-block small uppercase tracking-wider">Price per night</span>
            <span class="fs-4 fw-bold text-danger">₹<%= listing.price ? listing.price.toLocaleString("en-IN") : '0' %></span>
          </div>
          <div class="col-4 border-end">
            <span class="text-muted d-block small">Location</span>
            <span class="fs-5 fw-semibold text-dark"><%= listing.location %></span>
          </div>
          <div class="col-4">
            <span class="text-muted d-block small">Country</span>
            <span class="fs-5 fw-semibold text-dark"><%= listing.country %></span>
          </div>
        </div>

        <div class="mt-4 pt-3 d-flex gap-2">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger px-4 rounded-pill">Edit Details</a>
          
          <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline">
            <button class="btn btn-outline-dark px-4 rounded-pill">Delete Place</button>
          </form>
          
          <a href="/listings" class="btn btn-outline-secondary px-4 rounded-pill ms-auto">Back to Map</a>
        </div>
      </div>
    </div>

    <!-- Review Section -->
    <hr class="my-5">
    <div class="row">
      <div class="col-md-5 col-12 mb-4">
        <h4 class="fw-bold mb-3">Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
          <div class="mb-3">
            <label for="rating" class="form-label">Rating</label>
            <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range" style="accent-color: #dc3545;">
          </div>
          
          <div class="mb-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea id="comment" name="review[comment]" rows="4" class="form-control" placeholder="Share your experience..." required></textarea>
            <div class="invalid-feedback">Please write a comment.</div>
          </div>
          
          <button class="btn btn-dark px-4 py-2 rounded-pill">Submit Review</button>
        </form>
      </div>

      <!-- Existing Reviews -->
      <div class="col-md-7 col-12">
        <h4 class="fw-bold mb-3">Reviews (<%= listing.reviews.length %>)</h4>
        
        <% if (listing.reviews.length === 0) { %>
          <div class="alert alert-light text-center py-4 border">
            <p class="text-muted mb-0">No reviews yet. Be the first to review this paradise!</p>
          </div>
        <% } else { %>
          <div class="row row-cols-1 row-cols-sm-2 g-3">
            <% for (let review of listing.reviews) { %>
              <div class="col">
                <div class="card shadow-sm border-0 h-100 rounded-3">
                  <div class="card-body p-3 d-flex flex-column justify-content-between">
                    <div>
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-bold mb-0 text-dark"><%= review.author && review.author.username ? review.author.username : 'Wanderer' %></h6>
                        <span class="badge bg-warning text-dark">★ <%= review.rating %> / 5</span>
                      </div>
                      <p class="card-text text-secondary mb-3 small" style="line-height: 1.5;"><%= review.comment %></p>
                    </div>
                    
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="mt-auto pt-2">
                      <button class="btn btn-sm btn-outline-danger px-3 py-1 rounded-pill w-100">Delete</button>
                    </form>
                  </div>
                </div>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>

  </div>
</div>
