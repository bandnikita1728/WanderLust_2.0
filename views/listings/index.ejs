<% layout("layouts/boilerplate") %>
<div class="container overflow-hidden pb-5">
  <div class="row align-items-center mb-4 mt-2">
    <div class="col-sm-6 text-center text-sm-start">
      <h2 class="fw-bold text-dark mb-0 d-flex align-items-center justify-content-center justify-content-sm-start">
        <i class="fa-solid fa-umbrella-beach text-danger me-2"></i>Explore Listings
      </h2>
    </div>
    <div class="col-sm-6 text-center text-sm-end mt-3 mt-sm-0">
      <a href="/listings/new" class="btn btn-danger px-4 py-2 rounded-pill shadow-sm">
        <i class="fa-solid fa-house-chimney-medical me-2"></i>Add Listing
      </a>
    </div>
  </div>

  <% if (!allListings || allListings.length === 0) { %>
    <div class="text-center py-5 my-5 border rounded-4 bg-light shadow-sm">
      <h3 class="text-muted fw-bold">No Listings Found</h3>
      <p class="text-secondary pb-3">There are no spots listed at the moment. Be the first to share one!</p>
      <a href="/listings/new" class="btn btn-danger px-4 rounded-pill">Create a Listing</a>
    </div>
  <% } else { %>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
      <% for (let listing of allListings) { %>
        <div class="col">
          <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-card" style="transition: all 0.3s ease;">
            <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1540555700478-4be289fbecef?q=80&w=1000' %>" 
                 class="card-img-top w-100" 
                 style="height: 250px; object-fit: cover;" 
                 alt="<%= listing.title %>">
            
            <div class="card-body d-flex flex-column p-4">
              <h5 class="card-title text-dark fw-bold mb-1 text-truncate"><%= listing.title %></h5>
              <p class="text-muted small mb-2 d-flex align-items-center">
                <i class="fa-solid fa-location-dot text-danger me-1"></i><%= listing.location %>, <%= listing.country %>
              </p>
              
              <div class="d-flex align-items-baseline mb-3 mt-auto">
                <span class="fs-4 fw-bold text-danger">₹<%= listing.price ? listing.price.toLocaleString("en-IN") : '0' %></span>
                <span class="text-muted ms-1 small">/ night</span>
              </div>
              
              <a href="/listings/<%= listing._id %>" class="btn btn-outline-danger rounded-pill w-100 py-2 font-semibold">
                View Details
              </a>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</div>
